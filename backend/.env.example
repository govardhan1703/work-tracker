# Copy to .env and fill in values. Never commit .env.

PORT=3001

# Atlas connection string (include database name before ?, e.g. /track)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.host.mongodb.net/track?retryWrites=true&w=majority

# Comma-separated browser origins allowed (your deployed frontend). Localhost is always allowed by the server.
# Example: https://my-app.vercel.app
CORS_ORIGIN=

# Optional: if mongodb+srv fails locally, try leaving unset (uses 8.8.8.8) or set to: system
# MONGODB_DNS_SERVERS=system
